# ════════════════════════════════════════════════════════════════
#  .env.example — copy to .env.local and fill in.
#
#  Every variable consumed by code lives here. Keep in sync with
#  the value — reviewers should be able to grep .env.example to see
#  what a config change is about.
# ════════════════════════════════════════════════════════════════

# ── Node environment ──────────────────────────────────────────────
NODE_ENV=development

# ── PostgreSQL (PRIMARY — the only runtime database) ─────────────
# Architecture freeze: PostgreSQL is the only runtime DB.
# Prefer discrete PG* over a connection string.
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=CHANGE_ME
PGDATABASE=quantorus365
# Set PGSSL=true if the server requires TLS.
# PGSSL=true

# ── MySQL (MIGRATION SOURCE ONLY — do not use for new code) ──────
# These vars are consumed only by the one-way backfill tooling under
# scripts/ and the legacy `@/lib/db` shim that is being removed as part
# of the Phase-2 cutover. No runtime code should read from MySQL.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=quantorus365

# Phase-2 dual-write toggle. Unset = Postgres-only write path.
# When set, every snapshot is also mirrored to this MySQL table during
# the cutover observation window. Remove once Phase 2 is done.
# MYSQL_DUAL_WRITE_TABLE=market_snapshots_current_mirror

# ── Session / encryption ──────────────────────────────────────────
SESSION_SECRET=CHANGE_ME_64_HEX_CHARS
SESSION_MAX_AGE=86400
ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARS

# ── IndianAPI (PRIMARY live feed — required) ─────────────────────
# Architecture freeze: IndianAPI is the primary source of truth for
# all market-data reads (quotes, historical candles, movers,
# corporate intel, fundamentals).
INDIAN_API_KEY=REPLACE_WITH_YOUR_KEY
INDIAN_API_BASE_URL=https://stock.indianapi.in
# INDIANAPI_TIMEOUT_MS=2000

# ── Yahoo (FALLBACK only — policy-controlled) ────────────────────
# Set YAHOO_ENABLED=false to remove Yahoo from the fallback chain
# entirely. When disabled the chain collapses to IndianAPI → Cache →
# PostgreSQL (stale). Recommended for environments where even 15-min
# delayed data is unsafe to serve.
YAHOO_ENABLED=true

# ── Kite (BROKER / EXECUTION ONLY) ────────────────────────────────
# Kite is NOT a market-data source. It is used only by
# src/lib/execution/* for order placement, broker callbacks, and
# session management. `MarketDataProvider` does not import KiteAdapter.
# Re-generate keys at https://developers.kite.trade/ — never commit them.
KITE_API_KEY=REPLACE
KITE_API_SECRET=REPLACE

# ── Provider enforcement tripwire ────────────────────────────────
# off | warn | throw
ENFORCE_PROVIDER=off

# ── Provider freshness ───────────────────────────────────────────
# Retained for the execution module's Kite session freshness guard.
# Not consumed by the market-data provider (Kite is not in that chain).
MAX_KITE_AGE_MS=3000

# ── Microservice auth (required in production) ───────────────────
SERVICE_AUTH_TOKEN=CHANGE_ME_shared_bearer_token

# ── Service ports (docker-compose passes these in, but local runs
#    use the defaults baked into each server.ts) ──────────────────
MARKET_INGESTION_PORT=4100
MARKET_INTELLIGENCE_PORT=4200
ALERTING_PORT=4300
SIGNAL_ENGINE_PORT=4400
PORTFOLIO_PORT=4500
IDENTITY_PORT=4600
REPORTING_PORT=4700

# Service URLs — in docker-compose these are set to service DNS
# names. Locally you can leave them unset; RPC client falls back
# to http://localhost:<defaultPort>.
# MARKET_INGESTION_URL=http://market-ingestion:4100
# MARKET_INTELLIGENCE_URL=http://market-intelligence:4200
# ALERTING_URL=http://alerting:4300
# SIGNAL_ENGINE_URL=http://signal-engine:4400
# PORTFOLIO_URL=http://portfolio:4500
# IDENTITY_URL=http://identity:4600
# REPORTING_URL=http://reporting:4700

# ── Next.js ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000/
NEXT_PUBLIC_APP_NAME=Quantorus365
STREAM_WS_PORT=3001

# ── Redis (optional in dev; required for cross-service cache later) ─
REDIS_DISABLED=1
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_USER=default
# REDIS_PASSWORD=CHANGE_ME

# ── Scheduler / Logging ──────────────────────────────────────────
# SCHEDULER_WATCHLIST=RELIANCE,TCS,HDFCBANK,INFY,ICICIBANK
LOG_LEVEL=info

# ── Seed users (development only) ────────────────────────────────
# SEED_ADMIN_PASSWORD=CHANGE_ME
# SEED_JOHN_PASSWORD=CHANGE_ME
# SEED_PRIYA_PASSWORD=CHANGE_ME
