{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": "../..",
    "paths": {
      "@/*": ["src/*"],
      "@contracts/*": ["packages/contracts/src/*"],
      "@eventbus/*": ["packages/eventbus/src/*"],
      "@rpc/*": ["packages/rpc/src/*"]
    },
    "rootDir": "..",
    "outDir": "dist",
    "noEmit": false,
    "module": "commonjs",
    "target": "es2020"
  },
  "include": ["src/**/*.ts", "../_shared/**/*.ts"]
}
