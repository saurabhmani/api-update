{
  "name": "quantorus365",
  "version": "2.1.0",
  "description": "Quantorus365 — Institutional Stock Intelligence Platform",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "node server.js",
    "lint": "next lint",
    "db:migrate": "tsx src/lib/db/migrate.ts",
    "db:migrate:pg": "tsx src/lib/db/postgres/migrate.ts",
    "db:check:pg": "tsx scripts/validatePg.ts",
    "db:check:pg:insert": "tsx scripts/validatePg.ts --insert",
    "db:validate:pg": "tsx src/scripts/validateMysqlVsPostgres.ts",
    "db:validate:data": "tsx scripts/validateData.ts",
    "db:backfill:pg": "tsx scripts/backfillFromMysql.ts",
    "db:sql-lint": "tsx scripts/sqlRewriteHelper.ts",
    "check:provider": "tsx scripts/checkProviderConsistency.ts",
    "db:migrate-intel": "ts-node -P tsconfig.node.json -r tsconfig-paths/register src/lib/db/migrateIntelligence.ts",
    "db:migrate-market": "ts-node -P tsconfig.node.json -r tsconfig-paths/register src/lib/db/migrateMarketData.ts",
    "db:migrate-canonical": "tsx src/lib/db/migrateCanonical.ts",
    "db:migrate-all": "npm run db:migrate && npm run db:migrate-intel && npm run db:migrate-market && npm run db:migrate-q365 && npm run db:migrate-canonical",
    "scheduler": "ts-node -P tsconfig.node.json -r tsconfig-paths/register src/lib/workers/scheduler.ts",
    "scheduler:dev": "NODE_ENV=development ts-node -P tsconfig.node.json -r tsconfig-paths/register src/lib/workers/scheduler.ts",
    "learning-scheduler": "tsx src/lib/workers/learningScheduler.ts",
    "learning-scheduler:dev": "NODE_ENV=development tsx src/lib/workers/learningScheduler.ts",
    "manipulation-scan": "tsx src/lib/workers/manipulationScannerCli.ts",
    "manipulation-scan:dev": "NODE_ENV=development tsx src/lib/workers/manipulationScannerCli.ts",
    "news-scheduler": "tsx src/lib/workers/newsIngestionScheduler.ts",
    "news-scheduler:dev": "NODE_ENV=development tsx src/lib/workers/newsIngestionScheduler.ts",
    "db:migrate-q365": "ts-node -P tsconfig.node.json -r tsconfig-paths/register src/lib/db/migrateQ365.ts",
    "db:seed-users": "tsx src/lib/db/seedUsers.ts",
    "db:ensure": "tsx src/lib/db/ensureSchemasCli.ts",
    "ws-server": "tsx src/lib/ws/streamServerCli.ts",
    "db:setup": "ts-node -P tsconfig.node.json src/lib/db/setup.ts",
    "test:phase1": "tsx src/__tests__/backtestingPhase1.test.ts",
    "test:phase2": "tsx src/__tests__/backtestingPhase2.test.ts",
    "test:phase3": "tsx src/__tests__/backtestingPhase3.test.ts",
    "test:phase4": "tsx src/__tests__/backtestingPhase4.test.ts",
    "test:linkage": "tsx src/__tests__/backtestingFinalLinkage.test.ts",
    "test:manipulation": "tsx src/__tests__/manipulationEnginePhase1.test.ts",
    "test:manipulation2": "tsx src/__tests__/manipulationEnginePhase2.test.ts",
    "test:manipulation3": "tsx src/__tests__/manipulationEnginePhase3.test.ts",
    "test:verify": "tsx src/__tests__/verifyEnd2End.ts",
    "test:e2e": "tsx src/__tests__/runEnd2End.ts",
    "test:all": "npm run test:phase1 && npm run test:phase2 && npm run test:phase3 && npm run test:phase4 && npm run test:linkage",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:pipeline": "tsx src/__tests__/endToEndPipeline.test.ts",
    "test:architecture": "tsx src/__tests__/architectureVerification.test.ts",
    "test:news-intelligence": "vitest run --reporter verbose newsSignalIntegration newsContextualModifiers newsDexterNarrative"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "^2.1.92",
    "@types/pg": "^8.20.0",
    "axios": "^1.7.2",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "compression": "^1.7.4",
    "crypto": "^1.0.1",
    "dotenv": "^16.4.5",
    "framer-motion": "^12.38.0",
    "ioredis": "^5.4.1",
    "json2csv": "^6.0.0-alpha.2",
    "kiteconnect": "^5.2.0",
    "lucide-react": "^0.394.0",
    "mysql2": "^3.20.0",
    "next": "14.2.5",
    "node-cache": "^5.1.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.14",
    "pdfkit": "^0.15.0",
    "pg": "^8.20.0",
    "protobufjs": "^7.4.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "recharts": "^2.12.7",
    "sass": "^1.77.4",
    "slugify": "^1.6.6",
    "speakeasy": "^2.0.0",
    "uuid": "^10.0.0",
    "winston": "^3.14.2",
    "ws": "^8.18.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.19.39",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.15",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/speakeasy": "^2.0.10",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.12",
    "eslint": "^8",
    "eslint-config-next": "14.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
